meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{base_url}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "test@example.com",
    "password": "password123"
  }
}

tests {
  if (res.status === 200 && res.body.data && res.body.data.token) {
    bru.setEnvVar("token", res.body.data.token);
    bru.setVar("token", res.body.data.token);
  }
}
