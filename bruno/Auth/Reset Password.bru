meta {
  name: Reset Password
  type: http
  seq: 7
}

post {
  url: {{base_url}}/auth/password/reset
  body: json
  auth: none
}

body:json {
  {
    "token": "paste-token-from-email-here",
    "email": "test@example.com",
    "password": "newpassword123",
    "password_confirmation": "newpassword123"
  }
}
